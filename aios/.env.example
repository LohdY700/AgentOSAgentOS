# AIOS environment example
# Copy to .env (or export manually in shell)

# Hugging Face token (recommended for langchain memory warmup)
# Prevents anonymous warning and improves rate-limit reliability.
HF_TOKEN=hf_xxx_your_token

# Optional: quieter runtime behavior
HF_HUB_DISABLE_PROGRESS_BARS=1
TOKENIZERS_PARALLELISM=false
TRANSFORMERS_VERBOSITY=error
